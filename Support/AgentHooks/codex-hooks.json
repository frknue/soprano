{
  "description": "Report Codex lifecycle events to the containing Soprano pane.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "test -z \"$SOPRANO_BIN\" || \"$SOPRANO_BIN\" agent-event ready --profile codex --title \"Codex\" --body \"Ready for a prompt\"",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "test -z \"$SOPRANO_BIN\" || \"$SOPRANO_BIN\" agent-event running --profile codex --title \"Codex\" --body \"Working\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "test -z \"$SOPRANO_BIN\" || \"$SOPRANO_BIN\" agent-event needs-input --profile codex --notify --title \"Codex\" --body \"Response ready\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "test -z \"$SOPRANO_BIN\" || \"$SOPRANO_BIN\" agent-event needs-input --profile codex --notify --title \"Codex\" --body \"Approval or input required\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
